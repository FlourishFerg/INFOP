# =========================================================
# InfoPouch Backend - Production Environment Variables (Render)
# =========================================================
# Copy these into Render's Environment settings (Dashboard → Environment).
# Replace placeholder values before deploying.
# =========================================================

SPRING_PROFILES_ACTIVE=prod

# Database (example for Neon / Postgres)
# Format: jdbc:postgresql://<host>/<dbname>?sslmode=require
DATABASE_URL=jdbc:postgresql://ep-xxx-xxxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=your-neon-password

# JWT — must be at least 32 characters, keep this secret
# Generate one: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters

# App base URL — used in verification/reset email links
# Set to your Render service URL (https)
APP_BASE_URL=https://your-app.onrender.com
